{
  "name": "{{projectName}}",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "check": "turbo lint format:check typecheck",
    "fix": "turbo lint:fix format"
  },
  "devDependencies": {
    "oxfmt": "latest",
    "oxlint": "latest",
    "turbo": "^2.5.0",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.2.5",
  "catalog": {
    "@tailwindcss/vite": "^4.1.3",
    "@tanstack/react-query": "^5.72.2",
    "@tanstack/react-router": "^1.166.0",
    "@tanstack/react-start": "^1.166.0",
    "@trpc/client": "^11.1.0",
    "@trpc/server": "^11.1.0",
    "@trpc/tanstack-react-query": "^11.1.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "superjson": "^2.2.2",
    "tailwindcss": "^4.1.3",
    "typescript": "^5.8.2",
    "vite": "^6.3.1",
    "vite-tsconfig-paths": "^4.3.2",
    "zod": "^3.24.3"
  }
}
