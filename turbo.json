{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "persistent": true,
      "cache": false
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "test/**", "template/**"],
      "outputs": []
    },
    "//#lint": {},
    "//#lint:fix": {
      "cache": false
    },
    "//#format": {
      "cache": false
    },
    "//#format:check": {},
    "clean": {
      "cache": false
    }
  }
}
